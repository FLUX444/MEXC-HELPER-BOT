# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_@BotFather
TELEGRAM_CHAT_ID=your_chat_id

# Redis (optional; in-memory state if not set)
REDIS_URL=redis://localhost:6379/0

# MEXC (опционально: сканер работает без ключа; ключ нужен для торговли/приватных данных)
# MEXC_API_KEY=your_access_key
# MEXC_SECRET_KEY=your_secret_key
# Привязанный IP на MEXC должен совпадать с IP, с которого запускается бот
MEXC_KLINE_BATCH=20
